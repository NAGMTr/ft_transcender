{
  "info": {
    "_postman_id": "b8b9d9e2-2a6e-4f1f-8a18-7c51d6c7d5f2",
    "name": "ft_transcender - Users",
    "description": "Reusable requests for creating a user and opening the profile page in the ft_transcender project.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "username",
      "value": "new_user"
    },
    {
      "key": "email",
      "value": "new_user@example.com"
    },
    {
      "key": "password",
      "value": "ChangeMe123!"
    },
    {
      "key": "avatarUrl",
      "value": "https://i.imgur.com/6VBx3io.png"
    }
  ],
  "item": [
    {
      "name": "Create user",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/users"
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"avatar_url\": \"{{avatarUrl}}\",\n  \"is_online\": true\n}"
        },
        "description": "Creates a user record that can be loaded later by GET /users/:username in Profile.tsx."
      }
    },
    {
      "name": "Open profile",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users/{{username}}"
        },
        "description": "Fetches the profile data consumed by app-frontend/src/pages/Profile.tsx."
      }
    }
  ]
}
